            <ColorSwatch name="Success" hslValue="hsl(151 44% 52%)" hexValue="#52B788" description="Success state" />
            <ColorSwatch name="Warning" hslValue="hsl(71 100% 75%)" hexValue="#CFFF8B" description="Warning state" />
            <ColorSwatch name="Error" hslValue="hsl(6 74% 50%)" hexValue="#D1392E" description="Error state" />
