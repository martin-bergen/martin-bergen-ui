        <Section padding="xl" background="muted">
          <div className="mb-12">
            <h2 className="text-3xl font-serif text-berget-brand-peak mb-4">Typography</h2>
            <p className="text-berget-brand-peak/70">Font families and type scale</p>
          </div>

          <div className="space-y-12">
            <div>
              <h3 className="text-berget-brand-peak/60 text-sm mb-6">Serif (Ovo) - Headings</h3>
              <div className="space-y-8">
                <div>
                  <h1 className="text-5xl font-serif text-berget-brand-peak mb-2">Heading 1</h1>
                  <div className="text-xs text-berget-brand-peak/50 font-mono">5rem (80px) / 5.5rem line-height</div>
