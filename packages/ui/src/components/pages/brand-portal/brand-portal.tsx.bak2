                </div>
              </div>
            </div>

            <div>
              <h3 className="text-berget-brand-peak/60 text-sm mb-6">Sans (DM Sans) - Body & UI</h3>
              <div className="space-y-6">
                <div>
                  <h3 className="text-2xl font-sans text-berget-brand-peak mb-2">Heading 3</h3>
                  <div className="text-xs text-berget-brand-peak/50 font-mono">1.5rem (24px) / 2rem line-height</div>
