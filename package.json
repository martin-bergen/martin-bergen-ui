{
  "name": "ui",
  "version": "1.0.0",
  "description": "Berget Design System monorepo",
  "private": true,
  "license": "ISC",
  "scripts": {
    "build": "pnpm --filter @berget-ai/ui build",
    "storybook": "pnpm --filter storybook dev",
    "build-keycloak-theme": "pnpm --filter keycloak-theme run build-keycloak-theme",
    "start-keycloak": "pnpm --filter keycloak-theme run start-keycloak"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"],
    "overrides": {
      "react": "^19.0.0",
      "react-dom": "^19.0.0"
    }
  }
}
